# Staged onboarding. On rules acceptance: grant the newcomer (holding) role and
# arm a one-shot timer to promote later. On the timer re-fire: promote to the
# full-member role and, only if that succeeded, remove the holding role. Config
# values (role ids, delay) are baked in as literals at install time — see the
# extension manifest. Both role ids are mirrored into settings["allowed_role_ids"].
#
# Idempotent: member_rules_accepted may fire more than once (cache-miss
# at-least-once + startup replay), and both re-run paths only re-fire for a member
# holding no role yet, so re-granting the holding role (a Discord no-op) and
# re-arming the timer is the intended recovery. add_role returning False when the
# member has left gates the holding-role removal, so a stale promotion is a no-op.
PROMOTION_DELAY_SECONDS = {{cfg.promotion_delay_hours}} * 3600

if context["trigger_type"] == "member_rules_accepted":
    member_id = context["member_id"]
    await add_role(member_id, {{cfg.newcomer_role_id}}, reason="onboarding: rules accepted")
    await schedule_timer(PROMOTION_DELAY_SECONDS, {"member_id": member_id})
elif context["trigger_type"] == "timer":
    member_id = context["payload"]["member_id"]
    promoted = await add_role(member_id, {{cfg.full_member_role_id}}, reason="onboarding: promotion")
    if promoted:
        await remove_role(member_id, {{cfg.newcomer_role_id}}, reason="onboarding: promotion")
